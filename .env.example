# ─── LLM ──────────────────────────────────────────────────────────────────────
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: defaults to gemini-2.5-flash (Gemini 1.5 is retired on the API).
# Examples: gemini-2.5-flash | gemini-2.5-pro | gemini-3.1-flash-lite-preview | gemini-3-flash-preview
GEMINI_MODEL=gemini-2.5-flash

# ─── EMBEDDINGS ───────────────────────────────────────────────────────────────
# HuggingFace (Router API): use a token with "Make calls to Inference Providers"
# https://huggingface.co/settings/tokens/new?ownUserPermissions=inference.serverless.write&tokenType=fineGrained
HF_API_TOKEN=your_hf_token_here
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Supabase project: https://supabase.com/dashboard (use https://xxx.supabase.co for the Python client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
# Database password (Settings → Database) — only for scripts/apply_supabase_schema.py
# SUPABASE_DB_PASSWORD=your_database_password

# ─── GOOGLE CALENDAR & GMAIL ──────────────────────────────────────────────────
# Google Cloud Console: https://console.cloud.google.com
# Enable: Google Calendar API, Gmail API, Google Meet (via Calendar)
# Create OAuth 2.0 Client ID (Desktop or Web). The refresh token MUST be obtained
# with the SAME client id + secret you put here, or you get invalid_client.
# If you rotate the client secret in Console, generate a new refresh token.
# invalid_grant / "Token has been expired or revoked" = refresh token is dead; run:
#   python scripts/google_oauth_refresh_token.py
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token
GOOGLE_CALENDAR_ID=youremail@gmail.com
CALENDAR_TIMEZONE=Africa/Addis_Ababa

# ─── TELEGRAM (handoff alerts) ────────────────────────────────────────────────
# BotFather + chat id — see docs/telegram_setup.md (webhook + owner reply → visitor email)
TELEGRAM_BOT_TOKEN=123456789:AA_your_bot_token_from_BotFather
TELEGRAM_CHAT_ID=your_numeric_chat_id
# Same string you pass to setWebhook secret_token= (header X-Telegram-Bot-Api-Secret-Token)
# TELEGRAM_WEBHOOK_SECRET=generate_a_long_random_secret

# ─── RAG SETTINGS ─────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_CONFIDENCE_THRESHOLD=0.72
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64

# ─── API SETTINGS ─────────────────────────────────────────────────────────────
API_SECRET_KEY=generate_a_long_random_string_here
ALLOWED_ORIGINS=https://yabibal.site,https://www.yabibal.site,http://localhost:3000
PORT=8000
# Terminal logging: INFO = pipeline + HTTP summary; DEBUG = also httpx / low-level HTTP
LOG_LEVEL=INFO
# Public API protection
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_CHAT_PER_MINUTE=15
# RATE_LIMIT_BLOG_PER_MINUTE=120
# RATE_LIMIT_DEFAULT_PER_MINUTE=90
# BLOG_API_CACHE_TTL_SECONDS=45

# ─── PORTFOLIO OWNER ──────────────────────────────────────────────────────────
OWNER_NAME=Yabibal
OWNER_ROLE=Full-Stack & AI Engineer
PORTFOLIO_URL=https://yabibal.site
# Chat persona (single assistant voice in prompts)
ASSISTANT_NAME=Aegis

# ─── BLOG (draft pipeline / GitHub Actions) ───────────────────────────────────
# After Gemini writes a post: draft (default) | review (queue for publish job) | published (live now)
# BLOG_POST_STATUS_AFTER_WRITE=published
# BLOG_DEFAULT_OG_IMAGE=https://...
# BLOG_FALLBACK_GEMINI_IDEA=true
# BLOG_GENERATE_IMAGES=true
# Native image model (must support image output). Default in code: gemini-2.5-flash-image
# BLOG_IMAGE_MODEL=gemini-2.5-flash-image
# BLOG_STAGE_RETRY_ATTEMPTS=3
# BLOG_STAGE_RETRY_BASE_SECONDS=2
# BLOG_QUALITY_GATE_ENABLED=true
# BLOG_QUALITY_MIN_WORDS=450
# BLOG_QUALITY_MIN_HEADINGS=3
# BLOG_DUPLICATE_SIM_THRESHOLD=0.72
# BLOG_QUALITY_BLOCK_ON_FAIL=false
# BLOG_BANNED_PHRASES=as an ai language model,here is the article,in conclusion,overall,to summarize
# Cloudinary (optional; if missing, falls back to BLOG_DEFAULT_OG_IMAGE)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
# CLOUDINARY_FOLDER=aegis/blog
# BLOG_PIPELINE_RUN_KEY=blog-draft-<ci-run-id>
# Optional publish webhook (called when a post transitions to published)
# BLOG_PUBLISH_WEBHOOK_URL=https://example.com/hooks/blog-published
# BLOG_PUBLISH_WEBHOOK_SECRET=shared_hmac_secret
# BLOG_PUBLISH_WEBHOOK_TIMEOUT_SECONDS=10
# BLOG_PUBLISH_WEBHOOK_MAX_ATTEMPTS=3
# BLOG_PUBLISH_WEBHOOK_BACKOFF_SECONDS=2
